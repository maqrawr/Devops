        retiro = int(input("Cuanta cantidad desea sacar: "))
        if retiro > saldo:
            print("no cuenta con el saldo suficiente")
        else: 
            print("retiro exitoso de: ", retiro)
    if accion == 3:
        print("adios meow")
        break
else:
    print("introduce un NIP valido")
    



