# Diccionario de traducciones
diccionario = {
    "hola": {
        "ingles": "hello",
        "aleman": "hallo",
        "frances": "bonjour"
    },
    "gato": {
        "ingles": "cat",
        "aleman": "katze",
        "frances": "chat"
    }
}

# Entrada del usuario
palabra = input("Coloca tu palabra a traducir: ")
idioma = input("¿A qué idioma? (ingles, aleman, frances): ")

# Búsqueda
if palabra in diccionario:
    if idioma in diccionario[palabra]:
        print("Traducción:", diccionario[palabra][idioma])
    else:
        print("Idioma no disponible")
else:
    print("Palabra no encontrada")